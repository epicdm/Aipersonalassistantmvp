{
  "version": "6.2",
  "data_api_version": "3.0",
  "routing_model": {
    "TEMPLATE": []
  },
  "screens": [
    {
      "id": "TEMPLATE",
      "title": "Get Your AI Agent",
      "terminal": true,
      "data": {
        "greeting": {
          "type": "string",
          "__example__": "Welcome to Isola!"
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "template_form",
            "children": [
              {
                "type": "TextHeading",
                "text": "${data.greeting}"
              },
              {
                "type": "TextInput",
                "label": "Business Name",
                "name": "business_name",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "Footer",
                "label": "Get Started",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "business_name": "${form.business_name}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
