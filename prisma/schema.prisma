// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URLs configured in prisma.config.ts
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  plan             String   @default("free") // free, pro, business
  pendingPlan      String?  // Plan pending payment confirmation
  pendingPlanSince DateTime?
  lastBillingDate  DateTime?
  whatsappPhone    String?  // Primary WhatsApp number
  createdAt        DateTime @default(now())
  agents           Agent[]
  contacts         Contact[]
  conversations    Conversation[]
  reminders        Reminder[]
  bills            Bill[]
  todos            Todo[]
}

model Agent {
  id             String   @id @default(cuid())
  userId         String
  name           String
  template       String?
  purpose        String?
  tone           String?
  tools          String   @default("[]")
  approvalMode   String   @default("confirm")
  config         Json?    // Full config object
  guardrails     Json?    // { maxPrice, escalateOn[], quietHours, neverDiscuss[] }
  soul           String?  // Generated SOUL.md
  status         String   @default("draft") // draft, active, paused
  whatsappStatus String   @default("not_connected")
  whatsappNumber String?
  phoneNumber    String?
  phoneStatus    String   @default("pending")
  didNumber      String?  // Magnus provisioned DID number
  didSipUser     String?  // SIP username
  didSipPass     String?  // SIP password
  didSipServer   String?  // SIP server
  isActive        Boolean  @default(true)
  activationCode  String?  @unique
  whatsappPhone   String?  // The user's WhatsApp number bound to this agent
  activatedAt     DateTime?
  deployedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations     Conversation[]
  activities        AgentActivity[]
  reminders         Reminder[]
  bills             Bill[]
  todos             Todo[]
  whatsAppMessages  WhatsAppMessage[]
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  text      String
  datetime  DateTime
  recurring String?  // "daily", "weekly", "monthly", null
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model Bill {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  name      String
  amount    Float
  dueDate   DateTime
  recurring String?  // "monthly", "quarterly", "yearly", null
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model Todo {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  text      String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model AgentActivity {
  id        String   @id @default(cuid())
  agentId   String
  type      String   // conversation, appointment, payment, escalation, recommendation
  summary   String
  metadata  Json?    // Extra data relevant to the activity
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String?
  email     String?
  notes     String?
  tags      String   @default("[]")
  createdAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  contactId String
  channel   String   @default("whatsapp")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  direction      String   // inbound, outbound
  text           String
  status         String   @default("sent")
  approvedAt     DateTime?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  agentId   String
  phone     String
  role      String   // "user" or "assistant"
  content   String
  timestamp DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, phone, timestamp])
}
